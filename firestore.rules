rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User doc: any authenticated user can read basic profile info,
    // but only the owner can write. Ratings subcollection is readable by any
    // authenticated user, writable only by the owner.
    match /users/{userId} {
      allow read: if request.auth != null;
      // Owner can create/update/delete. Others can only update followerlist (for follow/unfollow).
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerlist'])
      );

      // Ratings subcollection
      match /ratings/{ratingId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;

        // Nested season docs under TV parent rating docs:
        // users/{userId}/ratings/tv_{mediaId}/seasons/{season}
        match /{document=**} {
          allow read: if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Custom lists subcollection (list page, profile lists tab)
      match /customLists/{listId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Per-media ratings index for social features.
    // mediaRatings/{mediaKey} holds aggregate (ratingCount, sumScores); userRatings subcollection holds per-user ratings.
    match /mediaRatings/{mediaKey} {
      allow read, write: if request.auth != null;
      match /userRatings/{ratingDocId} {
        allow read, write: if request.auth != null;

        // Nested season docs under per-user media ratings:
        // mediaRatings/{mediaKey}/userRatings/{uid}/seasons/{season}
        match /{document=**} {
          allow read, write: if request.auth != null;
        }
      }
    }

    // Usernames collection (for lookup): allow read for all authenticated; write only for owner of that username
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Activity feed collection.
    // activity/{activityId} — one doc per rating action
    // activity/{activityId}/comments/{commentId} — inline comments
    match /activity/{activityId} {
      allow read: if request.auth != null;

      // Only the owner can create their own activity entry
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;

      // Owner can delete; anyone authenticated can update voteCount/upvoterUids or commentCount
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'upvoterUids']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
      );

      match /comments/{commentId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;

        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }
    }

    // Discussion threads and replies per media item.
    // mediaDiscussions/{mediaKey}/threads/{threadId}/replies/{replyId}
    match /mediaDiscussions/{mediaKey} {
      // Parent doc not directly used, but allow authenticated reads
      allow read: if request.auth != null;
      allow write: if false;

      match /threads/{threadId} {
        // Anyone authenticated can read threads
        allow read: if request.auth != null;

        // Create: must be authenticated; uid field must match the requester
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        // Update: owner can edit; anyone authenticated can increment replyCount or toggle upvote
        allow update: if request.auth != null && (
          (resource.data.uid == request.auth.uid) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'upvoterUids'])) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount']))
        );

        // Only the author can delete their thread
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;

        // Replies subcollection
        match /replies/{replyId} {
          allow read: if request.auth != null;

          allow create: if request.auth != null
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 1000;

          allow update: if request.auth != null && (
            (resource.data.uid == request.auth.uid) ||
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'upvoterUids']))
          );

          allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
        }
      }
    }
  }
}
